#!/usr/bin/env bash
# BEGIN decision-log-enforcement v1
set -euo pipefail

# Factory-managed bypass: commits tagged [factory-managed] by the configured
# factory identity skip the <FILL-IN> scaffold/block checks. <FACTORY-MANAGED>
# is accepted as a passing scaffold state; PHASE-CLOSER aggregates these entries
# in a follow-up pass.
# Both conditions must match — tag AND identity — to prevent human commits that
# quote factory messages from accidentally bypassing enforcement. The identity
# match accepts forge.json:git_username as an exact committer email OR as a
# case-insensitive substring of the committer email/name, since git_username is
# often a short handle (e.g. "caleb") rather than the full commit email.
_is_factory_commit=0
if grep -qF '[factory-managed]' .git/COMMIT_EDITMSG 2>/dev/null; then
  _factory_email=""
  _forge_json="${HOME}/.claude/forge.json"
  if [ -f "$_forge_json" ]; then
    if command -v jq >/dev/null 2>&1; then
      _factory_email=$(jq -r '.git_username // ""' "$_forge_json" 2>/dev/null || true)
    fi
    # Dependency-free fallback: read git_username directly from the file. Handles
    # environments where jq is absent or python3 is a non-functional Windows
    # Store alias (command -v finds the stub but executing it yields nothing).
    if [ -z "$_factory_email" ]; then
      _factory_email=$(sed -n 's/.*"git_username"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_forge_json" 2>/dev/null || true)
    fi
  fi
  # Pure-bash identity match (no pipes/grep/sed — avoids Git-Bash pipe instability).
  _committer_ident=$(git var GIT_COMMITTER_IDENT 2>/dev/null || true)
  _committer_email=${_committer_ident##*<}   # strip up to and incl. "<"
  _committer_email=${_committer_email%%>*}    # strip from ">" onward
  _ident_lc=${_committer_ident,,}
  _fe_lc=${_factory_email,,}
  if [ -n "$_factory_email" ] && { [ "$_committer_email" = "$_factory_email" ] \
       || [[ "$_ident_lc" == *"$_fe_lc"* ]]; }; then
    _is_factory_commit=1
  fi
fi

# Stage 1: scaffold <FILL-IN> entry if code staged without decisions.md change
staged_code=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|js|py|rb|go|rs|cs|sql|sh)$' | grep -vE 'scripts/hooks/|\.git/' || true)
staged_decisions=$(git diff --cached --name-only --diff-filter=ACM | grep -c '^docs/decisions\.md$' || true)

if [ -n "$staged_code" ] && [ "$staged_decisions" -eq 0 ] && [ "$_is_factory_commit" -eq 0 ]; then
  cat >> docs/decisions.md <<'SCAFFOLD'

## $(date +%Y-%m-%d) — <FILL-IN>
- Symptom: <FILL-IN>
- Fix: <FILL-IN>
- Surfaces: <FILL-IN>
- Watch: <FILL-IN>
- Commit: <FILL-IN>
SCAFFOLD
  git add docs/decisions.md
  cat >&2 <<'ERRMSG'
Decision log entry required. Scaffold appended to docs/decisions.md.
Fill in the 5 remaining <FILL-IN> fields (Symptom, Fix, Surfaces, Watch, Commit) in docs/decisions.md, then re-stage and re-commit.
Bypass (use sparingly): git commit --no-verify
ERRMSG
  exit 1
fi

# Stage 2: block if <FILL-IN> still present in ADDED lines of staged docs/decisions.md
# Factory-managed commits may use <FACTORY-MANAGED> scaffold state; only <FILL-IN> blocks.
if [ "$staged_decisions" -gt 0 ] && [ "$_is_factory_commit" -eq 0 ]; then
  if git diff --cached -- docs/decisions.md | grep -E '^\+' | grep -q '<FILL-IN>'; then
    cat >&2 <<'ERRMSG'
docs/decisions.md still contains <FILL-IN> placeholders.
Fill them in before committing. Bypass (use sparingly): git commit --no-verify
See: docs/decisions.md
ERRMSG
    exit 1
  fi
fi
# END decision-log-enforcement v1
